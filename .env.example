# IA BCC webapp environment.
# Copy to .env.local and fill in values for local dev. NEVER commit .env.local.

# Supabase project URL and ANON public key.
# These are safe to ship to the browser — RLS policies on every table restrict
# what an authenticated user can read. Service role key is NEVER used in the
# webapp; it stays in Edge Function secrets only.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Optional: bypass auth for local development. Default: false (auth required).
# When set to true, the webapp uses the anon key directly without requiring
# a sign-in. Useful for development against demo data; NEVER enable in
# production deployments.
VITE_DEMO_MODE=false
